# Azure SQL Database Connection String
# Replace <USERNAME>, <PASSWORD>, <SERVER_NAME>, and <DATABASE_NAME> with your actual Azure credentials.
# CRITICAL: Ensure you use '&' before TrustServerCertificate, not ';'

DATABASE_URL=mssql+pyodbc://<USERNAME>:<PASSWORD>@<SERVER_NAME>.database.windows.net:1433/<DATABASE_NAME>?driver=ODBC+Driver+18+for+SQL+Server&TrustServerCertificate=yes